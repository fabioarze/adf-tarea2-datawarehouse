{
	"name": "df_carga_vacunas_pai",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_vacunas_pai_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_cat_vacunas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "Trim"
				},
				{
					"name": "IntervaloMninimoDias"
				},
				{
					"name": "CondicionEspecial"
				},
				{
					"name": "SitioAplicacion"
				},
				{
					"name": "select1"
				},
				{
					"name": "toInteger"
				}
			],
			"scriptLines": [
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as string,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          edad_minima_dias as string,",
				"          edad_maxima_dias as string,",
				"          intervalo_minimo_dias as string,",
				"          via_administracion as string,",
				"          sitio_aplicacion as string,",
				"          dosis_ml as string,",
				"          condicion_especial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(vacuna_id = trim(vacuna_id),",
				"          vacuna_nombre = trim(vacuna_nombre),",
				"          enfermedad_previene = trim(enfermedad_previene),",
				"          grupo_pai = trim(grupo_pai),",
				"          numero_dosis = trim(numero_dosis),",
				"          dosis_descripcion = trim(dosis_descripcion),",
				"          edad_aplicacion_descripcion = trim(edad_aplicacion_descripcion),",
				"          edad_minima_dias = trim(edad_minima_dias),",
				"          edad_maxima_dias = trim(edad_maxima_dias),",
				"          intervalo_minimo_dias = trim(intervalo_minimo_dias),",
				"          via_administracion = trim(via_administracion),",
				"          sitio_aplicacion = trim(sitio_aplicacion),",
				"          dosis_ml = trim(dosis_ml),",
				"          condicion_especial = trim(condicion_especial)) ~> Trim",
				"Trim derive(intervalo_minimo_dias = iif(isNull(intervalo_minimo_dias), 0, toInteger(intervalo_minimo_dias))) ~> IntervaloMninimoDias",
				"IntervaloMninimoDias derive(condicion_especial = iif(isNull(condicion_especial) || length(trim(condicion_especial)) == 0, 'Sin condición', condicion_especial)) ~> CondicionEspecial",
				"CondicionEspecial derive(sitio_aplicacion = case(     instr(lower(sitio_aplicacion), 'deltoid') > 0, 'Deltoides Brazo',     instr(lower(sitio_aplicacion), 'boca') > 0, 'Vía Oral',     instr(lower(sitio_aplicacion), 'muslo') > 0 || instr(lower(sitio_aplicacion), 'tercio') > 0, 'Muslo (Tercio Medio)',     isNull(sitio_aplicacion) || length(trim(sitio_aplicacion)) == 0, 'No especificado',     trim(sitio_aplicacion) )) ~> SitioAplicacion",
				"toInteger select(mapColumn(",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          enfermedad_previene,",
				"          grupo_pai,",
				"          numero_dosis,",
				"          dosis_descripcion,",
				"          edad_aplicacion_descripcion,",
				"          edad_minima_dias,",
				"          edad_maxima_dias,",
				"          intervalo_minimo_dias,",
				"          via_administracion,",
				"          sitio_aplicacion,",
				"          dosis_ml,",
				"          condicion_especial",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"SitioAplicacion derive(edad_minima_dias = toInteger(edad_minima_dias),",
				"          edad_maxima_dias = toInteger(edad_maxima_dias),",
				"          dosis_ml = toDecimal(dosis_ml),",
				"          numero_dosis = toInteger(numero_dosis)) ~> toInteger",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as integer,",
				"          dosis_descripcion as string,",
				"          via_administracion as string,",
				"          dosis_ml as decimal(5,2),",
				"          edad_minima_dias as integer,",
				"          edad_maxima_dias as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          enfermedad_previene,",
				"          grupo_pai,",
				"          numero_dosis,",
				"          dosis_descripcion,",
				"          via_administracion,",
				"          dosis_ml,",
				"          edad_minima_dias,",
				"          edad_maxima_dias",
				"     )) ~> sink1"
			]
		}
	}
}
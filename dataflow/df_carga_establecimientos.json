{
	"name": "df_carga_establecimientos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_establecimientos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "toBoolean"
				},
				{
					"name": "select1"
				},
				{
					"name": "toDouble"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as string,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(establecimiento_id = trim(establecimiento_id),",
				"          nombre_establecimiento = trim(nombre_establecimiento),",
				"          tipo_establecimiento = trim(tipo_establecimiento),",
				"          nivel_atencion = trim(nivel_atencion),",
				"          zona = trim(zona),",
				"          sedes = trim(sedes),",
				"          red_salud = trim(red_salud),",
				"          departamento = trim(departamento),",
				"          municipio = trim(municipio),",
				"          latitud = trim(latitud),",
				"          longitud = trim(longitud),",
				"          tiene_cadena_frio = trim(tiene_cadena_frio),",
				"          activo = trim(activo)) ~> derivedColumn1",
				"derivedColumn1 derive(tiene_cadena_frio = toBoolean(tiene_cadena_frio),",
				"          activo = toBoolean(activo),",
				"          nivel_atencion = toInteger(nivel_atencion)) ~> toBoolean",
				"toDouble select(mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          nivel_atencion,",
				"          zona,",
				"          sedes,",
				"          red_salud,",
				"          departamento,",
				"          municipio,",
				"          latitud,",
				"          longitud,",
				"          tiene_cadena_frio,",
				"          activo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"toBoolean derive(latitud = toDouble(\r",
				"    regexReplace(\r",
				"        replace(latitud, '.', ''), \r",
				"        '^(-?\\\\d{2})(\\\\d+)', \r",
				"        '$1.$2'\r",
				"    )\r",
				"),",
				"          longitud = toDouble(\r",
				"    regexReplace(\r",
				"        replace(longitud, '.', ''), \r",
				"        '^(-?\\\\d{2})(\\\\d+)', \r",
				"        '$1.$2'\r",
				"    )\r",
				")) ~> toDouble",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as integer,",
				"          departamento as string,",
				"          municipio as string,",
				"          tiene_cadena_frio as boolean,",
				"          latitud as decimal(10,8),",
				"          longitud as decimal(11,8)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          nivel_atencion,",
				"          departamento,",
				"          municipio,",
				"          tiene_cadena_frio,",
				"          latitud,",
				"          longitud",
				"     )) ~> sink1"
			]
		}
	}
}
{
	"name": "df_consolidacion_vacunacion",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "vacunacion_la_paz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "vacunacion_santa_cruz_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "vacunacion_rural_movil_csv",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_consolidada",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "union1"
				},
				{
					"name": "union2"
				},
				{
					"name": "RegistroIdPacienteId"
				},
				{
					"name": "Sexo"
				},
				{
					"name": "ComIndigena"
				},
				{
					"name": "AplicacionOportuna"
				},
				{
					"name": "EstablecimientoId"
				},
				{
					"name": "Departamento"
				},
				{
					"name": "FechaVacuna"
				},
				{
					"name": "Trim"
				},
				{
					"name": "Fechas"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_registro as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fec_nacimiento as string,",
				"          municipio as string,",
				"          pueblo_indigena as string,",
				"          fec_vacunacion as string,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as string,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          depto as string,",
				"          nro_lote as string,",
				"          temp_conservacion as string,",
				"          edad_dias as string,",
				"          via_aplicacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as string,",
				"          fecha_vacunacion as string,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as string,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as string,",
				"          edad_dias_aplicacion as string,",
				"          aplicacion_oportuna as string,",
				"          via_administracion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          record_id as string,",
				"          sync_timestamp as string,",
				"          device_id as string,",
				"          patient_id as string,",
				"          patient_ci as string,",
				"          patient_name as string,",
				"          patient_last_name_1 as string,",
				"          patient_last_name_2 as string,",
				"          patient_sex as string,",
				"          patient_birth_date as string,",
				"          patient_department as string,",
				"          patient_municipality as string,",
				"          patient_community as string,",
				"          patient_indigenous as string,",
				"          vaccination_date as string,",
				"          vaccine_code as string,",
				"          vaccine_name as string,",
				"          dose_number as string,",
				"          facility_code as string,",
				"          facility_name as string,",
				"          lot_number as string,",
				"          storage_temp_celsius as string,",
				"          patient_age_days as string,",
				"          administration_route as string,",
				"          gps_latitude as string,",
				"          gps_longitude as string,",
				"          gps_accuracy_meters as string,",
				"          observations as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source1 select(mapColumn(",
				"          registro_id = id_registro,",
				"          paciente_id = cod_paciente,",
				"          ci_paciente = documento_identidad,",
				"          nombre_paciente = nombres,",
				"          apellido_paterno = primer_apellido,",
				"          apellido_materno = segundo_apellido,",
				"          sexo = genero,",
				"          fecha_nacimiento = fec_nacimiento,",
				"          municipio_residencia = municipio,",
				"          comunidad_indigena = pueblo_indigena,",
				"          fecha_vacunacion = fec_vacunacion,",
				"          vacuna_id = cod_vacuna,",
				"          vacuna_nombre = desc_vacuna,",
				"          numero_dosis = nro_dosis,",
				"          establecimiento_id = cod_establecimiento,",
				"          nombre_establecimiento = desc_establecimiento,",
				"          departamento = depto,",
				"          lote_vacuna = nro_lote,",
				"          temperatura_conservacion = temp_conservacion,",
				"          edad_dias_aplicacion = edad_dias,",
				"          via_administracion = via_aplicacion",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source2 select(mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          ci_paciente,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_vacunacion,",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          numero_dosis,",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          departamento,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          aplicacion_oportuna,",
				"          via_administracion",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"source3 select(mapColumn(",
				"          registro_id = record_id,",
				"          paciente_id = patient_id,",
				"          ci_paciente = patient_ci,",
				"          nombre_paciente = patient_name,",
				"          apellido_paterno = patient_last_name_1,",
				"          apellido_materno = patient_last_name_2,",
				"          sexo = patient_sex,",
				"          fecha_nacimiento = patient_birth_date,",
				"          departamento = patient_department,",
				"          municipio_residencia = patient_municipality,",
				"          comunidad_indigena = patient_indigenous,",
				"          fecha_vacunacion = vaccination_date,",
				"          vacuna_id = vaccine_code,",
				"          vacuna_nombre = vaccine_name,",
				"          numero_dosis = dose_number,",
				"          establecimiento_id = facility_code,",
				"          nombre_establecimiento = facility_name,",
				"          lote_vacuna = lot_number,",
				"          temperatura_conservacion = storage_temp_celsius,",
				"          edad_dias_aplicacion = patient_age_days,",
				"          via_administracion = administration_route",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select1, select2 union(byName: true)~> union1",
				"union1, select3 union(byName: true)~> union2",
				"Trim derive(registro_id = iif(startsWith(registro_id, 'LP-'), replace(registro_id, 'LP-', 'REG-LP-'),     iif(startsWith(registro_id, 'MOVIL-'), replace(registro_id, 'MOVIL-', 'REG-RU-'),      registro_id)),",
				"          paciente_id = iif(startsWith(paciente_id, 'MOV-'), replace(paciente_id, 'MOV-', 'PAC-RU-'),     iif(startsWith(paciente_id, 'PAC-LP-'), paciente_id,      iif(startsWith(paciente_id, 'PAC-SC-'), paciente_id,      paciente_id)))) ~> RegistroIdPacienteId",
				"RegistroIdPacienteId derive(sexo = iif(upper(left(sexo, 1)) == 'M', 'M', 'F')) ~> Sexo",
				"Sexo derive(comunidad_indigena = iif(in(['SÍ', 'SI', 'TRUE', '1'], upper(toString(comunidad_indigena))), true(), false())) ~> ComIndigena",
				"ComIndigena derive(aplicacion_oportuna = iif(isNull(aplicacion_oportuna), true(), toBoolean(aplicacion_oportuna))) ~> AplicacionOportuna",
				"AplicacionOportuna derive(establecimiento_id = iif(startsWith(establecimiento_id, 'FAC-'), replace(establecimiento_id, 'FAC-', 'EST-RU-'),     iif(startsWith(establecimiento_id, 'EST-LP-'), establecimiento_id,      iif(startsWith(establecimiento_id, 'EST-SC-'), establecimiento_id,      establecimiento_id)))) ~> EstablecimientoId",
				"EstablecimientoId derive(departamento = initCap(     replace(         replace(lower(trim(departamento)), 'sta cruz de la sierra', 'santa cruz'),         'stacruz', 'santa cruz'     ) )) ~> Departamento",
				"Departamento derive(fecha_vacunacion = toString(     coalesce(         toTimestamp(fecha_vacunacion, 'dd/MM/yyyy'),         toTimestamp(fecha_vacunacion, 'yyyy-MM-dd\\'T\\'HH:mm:ss')     ),      'dd/MM/yyyy' )) ~> FechaVacuna",
				"union2 derive(registro_id = trim(registro_id),",
				"          paciente_id = trim(paciente_id),",
				"          ci_paciente = trim(ci_paciente),",
				"          nombre_paciente = trim(nombre_paciente),",
				"          apellido_paterno = trim(apellido_paterno),",
				"          apellido_materno = trim(apellido_materno),",
				"          sexo = trim(sexo),",
				"          fecha_nacimiento = trim(fecha_nacimiento),",
				"          municipio_residencia = trim(municipio_residencia),",
				"          comunidad_indigena = trim(comunidad_indigena),",
				"          fecha_vacunacion = trim(fecha_vacunacion),",
				"          vacuna_id = trim(vacuna_id),",
				"          vacuna_nombre = trim(vacuna_nombre),",
				"          numero_dosis = trim(numero_dosis),",
				"          establecimiento_id = trim(establecimiento_id),",
				"          nombre_establecimiento = trim(nombre_establecimiento),",
				"          departamento = trim(departamento),",
				"          lote_vacuna = trim(lote_vacuna),",
				"          temperatura_conservacion = trim(temperatura_conservacion),",
				"          edad_dias_aplicacion = trim(edad_dias_aplicacion),",
				"          via_administracion = trim(via_administracion),",
				"          aplicacion_oportuna = trim(aplicacion_oportuna)) ~> Trim",
				"FechaVacuna derive(fecha_vacunacion = toDate(\r",
				"    coalesce(\r",
				"        toTimestamp(fecha_vacunacion, 'dd/MM/yyyy'),\r",
				"        toTimestamp(fecha_vacunacion, 'yyyy-MM-dd\\'T\\'HH:mm:ss')\r",
				"    )\r",
				"),",
				"          fecha_nacimiento = toDate(\r",
				"    coalesce(\r",
				"        toTimestamp(fecha_nacimiento, 'dd/MM/yyyy'),\r",
				"        toTimestamp(fecha_nacimiento, 'yyyy-MM-dd\\'T\\'HH:mm:ss'),\r",
				"        toTimestamp(fecha_nacimiento, 'dd/MM/yyyy')\r",
				"    )\r",
				"),",
				"          nombre_completo = trim(concat(nombre_paciente, ' ', apellido_paterno, ' ', apellido_materno))) ~> Fechas",
				"Fechas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_completo as string,",
				"          sexo as string,",
				"          fecha_nacimiento as date,",
				"          fecha_vacunacion as timestamp,",
				"          vacuna_id as string,",
				"          establecimiento_id as string,",
				"          numero_dosis as integer,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as decimal(5,2),",
				"          edad_dias_aplicacion as integer,",
				"          aplicacion_oportuna as boolean,",
				"          canal_fuente as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     dateFormat:'dd/MM/yyyy',",
				"     timestampFormat:'dd/MM/yyyy',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          ci_paciente,",
				"          nombre_completo,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          fecha_vacunacion,",
				"          vacuna_id,",
				"          establecimiento_id,",
				"          numero_dosis,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          aplicacion_oportuna",
				"     )) ~> sink1"
			]
		}
	}
}